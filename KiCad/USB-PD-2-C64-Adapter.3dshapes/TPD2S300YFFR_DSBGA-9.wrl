#VRML V2.0 utf8
# Simple dimensionally-oriented placeholder model for TI TPD2S300YFFR DSBGA-9.
# Authored in millimetres; KiCad footprint uses scale 0.3937 for mm-authored VRML.

Transform {
  translation 0 0 0.15
  children [
    Shape {
      appearance Appearance {
        material Material {
          diffuseColor 0.08 0.08 0.08
          specularColor 0.25 0.25 0.25
          shininess 0.35
        }
      }
      geometry Box { size 1.40 1.40 0.30 }
    }
  ]
}

